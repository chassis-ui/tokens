{
  "name": "@chassis-ui/tokens",
  "version": "0.1.0",
  "description": "Design tokens for Chassis Design System. Includes token transformers, asset manager and icon generator",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chassis-ui/tokens.git"
  },
  "bugs": {
    "url": "https://github.com/chassis-ui/tokens/issues"
  },
  "homepage": "https://chassis-ui.com",
  "author": "Ozgur Gunes <o.gunes@gmail.com>",
  "license": "MIT",
  "keywords": [
    "chassis",
    "design system",
    "design tokens",
    "design assets",
    "figma variables",
    "style dictionary",
    "tokens studio",
    "token transform"
  ],
  "files": [
    "dist/**/*.{css,scss,json,js,ts}",
    "!.DS_Store"
  ],
  "chassis": {
    "defaults": {
      "theme": "light",
      "screen": "large"
    },
    "build": {
      "brands": [
        "chassis",
        "test"
      ],
      "themes": [
        "light",
        "dark"
      ],
      "screens": [
        "large",
        "medium",
        "small"
      ],
      "apps": {
        "docs": [
          "web"
        ],
        "test": [
          "ios",
          "android"
        ]
      }
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tokens:build && pnpm site:build",
    "clean": "node build/build-site.js clean",
    "dev": "pnpm astro:dev",
    "postinstall": "pnpm sync:submodules",
    "preview": "pnpm astro:preview",
    "test": "pnpm tokens:test",
    "validate": "node build/build.js validate",
    "tokens": "pnpm build:tokens",
    "tokens:build": "node build/tokens/build.js",
    "tokens:lint": "eslint --cache --cache-location .cache/.eslintcache build/tokens",
    "tokens:test": "vitest run --dir build/tokens/test",
    "site": "pnpm site:build && pnpm site:lint",
    "site:build": "node build/build-site.js",
    "site:format": "prettier --write --cache site",
    "site:lint": "pnpm site:lint:*",
    "site:lint:fusv": "find-unused-sass-variables site/src/scss/",
    "site:lint:eslint": "prettier -c --cache site",
    "site:lint:stylelint": "stylelint site/src/scss/ --cache --cache-location .cache/.stylelintcache",
    "site:lint:vnu": "node build/vnu-jar.js",
    "astro:dev": "astro dev --root site --port 4321",
    "astro:build": "astro build --root site",
    "astro:preview": "astro preview --root site",
    "check": "pnpm check:code & pnpm check:lockfile & pnpm check:pnpm & wait",
    "check:code": "pnpm site:lint",
    "check:lockfile": "lockfile-lint --allowed-hosts npm --allowed-schemes https: --empty-hostname false --type npm --path package-lock.json",
    "check:pnpm": "pnpm audit --audit-level moderate",
    "release:version": "node build/change-version.js",
    "sync:submodules": "node build/sync-submodules.js"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/markdown-remark": "^6.3.6",
    "@astrojs/mdx": "^4.3.5",
    "@astrojs/prism": "^3.3.0",
    "@astrojs/sitemap": "^3.6.0",
    "@babel/preset-env": "^7.28.3",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@eslint/js": "^9.36.0",
    "@chassis-ui/css": "github:chassis-ui/css#app/docs",
    "@chassis-ui/icons": "github:chassis-ui/icons#staging",
    "@stackblitz/sdk": "^1.11.0",
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@types/google.analytics": "^0.0.46",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/mime": "^3.0.4",
    "@types/node": "^22.18.6",
    "@types/prismjs": "^1.26.5",
    "@vitest/coverage-v8": "3.2.4",
    "astro": "^5.13.9",
    "astro-auto-import": "^0.4.4",
    "autoprefixer": "^10.4.21",
    "clean-css-cli": "^5.6.3",
    "clipboard": "^2.0.11",
    "eslint": "^9.36.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^61.0.2",
    "find-unused-sass-variables": "^6.1.0",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "globals": "^16.4.0",
    "htmlparser2": "^10.0.0",
    "image-size": "^2.0.2",
    "jest": "^30.1.3",
    "js-yaml": "^4.1.0",
    "lockfile-lint": "^4.14.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.1.0",
    "minimist": "^1.2.8",
    "npm-run-all2": "^7.0.2",
    "picocolors": "^1.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prismjs": "^1.30.0",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sass": "^1.93.0",
    "standard": "^17.1.2",
    "style-dictionary": "^4.4.0",
    "stylelint": "^16.24.0",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "tinycolor2": "^1.6.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vitest": "^3.2.4",
    "vnu-jar": "23.4.11",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6",
  "pnpm": {
    "overrides": {
      "chassis-docs": "link:../../../.local/share/pnpm/5/node_modules/@chassis-ui/docs",
      "@chassis-ui/docs": "link:../chassis-docs/packages/docs"
    }
  },
  "dependencies": {
    "@chassis-ui/docs": "link:../chassis-docs/packages/docs",
    "chassis-docs": "link:../../../.local/share/pnpm/5/node_modules/@chassis-ui/docs"
  }
}
