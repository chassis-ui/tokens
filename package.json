{
  "name": "@ozgurgunes/chassis-tokens",
  "version": "0.1.0",
  "description": "Design tokens for Chassis Design System. Includes token transformers, asset manager and icon generator",
  "license": "MIT",
  "homepage": "https://github.com/ozgurgunes/chassis-tokens",
  "type": "module",
  "keywords": [
    "chassis",
    "design system",
    "design tokens",
    "design assets",
    "figma variables",
    "style dictionary",
    "tokens studio",
    "token transform"
  ],
  "files": [
    "dist/**/*.{css,scss,json,js,ts}",
    "!.DS_Store"
  ],
  "chassis": {
    "defaults": {
      "theme": "light",
      "screen": "large"
    },
    "build": {
      "brands": [
        "chassis",
        "test"
      ],
      "themes": [
        "light",
        "dark"
      ],
      "screens": [
        "large",
        "medium",
        "small"
      ],
      "apps": {
        "docs": [
          "web"
        ],
        "test": [
          "ios",
          "android"
        ]
      }
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dist": "pnpm tokens",
    "build": "pnpm build:tokens && pnpm build:site",
    "dev": "astro dev --root site --port 4323",
    "test": "pnpm build:site && npm-run-all --parallel --aggregate-output --continue-on-error test:*",
    "tokens": "pnpm build:tokens",
    "change-version": "node build/change-version.js",
    "sync-submodules": "node build/sync-submodules.js",
    "release": "pnpm tokens && pnpm icons",
    "build:astro": "astro build --root site",
    "build:site": "node build/build-site.js",
    "build:tokens": "node build/tokens/build.js",
    "test:audit": "pnpm audit --audit-level moderate",
    "test:coverage": "vitest run --coverage",
    "test:lint": "npm-run-all docs-prettier-check docs-vnu",
    "test:prettier-check": "prettier -c --cache site",
    "test:prettier-format": "prettier --write --cache site",
    "test:eslint": "eslint --cache --cache-location .cache/.eslintcache .",
    "test:fusv": "find-unused-sass-variables site/src/scss/",
    "test:stylelint": "stylelint site/src/scss/ --cache --cache-location .cache/.stylelintcache",
    "test:tokens": "vitest run",
    "test:vnu": "node build/vnu-jar.js",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/markdown-remark": "^6.3.1",
    "@astrojs/mdx": "^4.2.6",
    "@astrojs/prism": "^3.2.0",
    "@astrojs/sitemap": "^3.3.1",
    "@babel/preset-env": "^7.28.3",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@ozgurgunes/chassis-css": "github:ozgurgunes/chassis-css#app/docs",
    "@ozgurgunes/chassis-icons": "github:ozgurgunes/chassis-icons#staging",
    "@stackblitz/sdk": "^1.11.0",
    "@tokens-studio/sd-transforms": "^1.2.12",
    "@types/google.analytics": "^0.0.46",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.5",
    "@types/mdast": "^4.0.4",
    "@types/mime": "^3.0.1",
    "@types/node": "^22.18.1",
    "@types/prismjs": "^1.26.0",
    "@vitest/coverage-v8": "3.2.4",
    "astro": "^5.13.7",
    "astro-auto-import": "^0.4.4",
    "autoprefixer": "^10.4.21",
    "clean-css-cli": "^5.6.3",
    "clipboard": "^2.0.11",
    "eslint": "^9.3.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "find-unused-sass-variables": "^6.1.0",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "globals": "^16.4.0",
    "htmlparser2": "^10.0.0",
    "image-size": "^2.0.2",
    "jest": "^30.1.3",
    "js-yaml": "^4.1.0",
    "lockfile-lint": "^4.14.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.0.7",
    "minimist": "^1.2.8",
    "npm-run-all2": "^7.0.2",
    "picocolors": "^1.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "prismjs": "^1.30.0",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sass": "^1.92.1",
    "standard": "^17.1.0",
    "style-dictionary": "^4.3.3",
    "tinycolor2": "^1.6.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vitest": "^3.2.4",
    "vnu-jar": "23.4.11",
    "zod": "^3.24.3"
  },
  "packageManager": "pnpm@9.15.5+sha512.845196026aab1cc3f098a0474b64dfbab2afe7a1b4e91dd86895d8e4aa32a7a6d03049e2d0ad770bbe4de023a7122fb68c1a1d6e0d033c7076085f9d5d4800d4"
}
