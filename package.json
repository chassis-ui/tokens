{
  "name": "@chassis-ui/tokens",
  "version": "0.1.4",
  "description": "Design tokens for Chassis Design System. Includes token transformers, asset manager and icon generator",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chassis-ui/tokens.git"
  },
  "bugs": {
    "url": "https://github.com/chassis-ui/tokens/issues"
  },
  "homepage": "https://chassis-ui.com",
  "author": "Ozgur Gunes <o.gunes@gmail.com>",
  "license": "MIT",
  "keywords": [
    "chassis",
    "design system",
    "design tokens",
    "design assets",
    "figma variables",
    "style dictionary",
    "tokens studio",
    "token transform"
  ],
  "files": [
    "dist/**/*.{css,scss,json,js,ts}"
  ],
  "chassis": {
    "build": {
      "brands": [
        "chassis",
        "example"
      ],
      "themes": [
        "light",
        "dark"
      ],
      "screens": [
        "large",
        "medium",
        "small"
      ],
      "apps": {
        "docs": [
          "web"
        ],
        "demo": [
          "ios",
          "android"
        ]
      }
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tokens:site && pnpm site:build",
    "clean": "pnpm site:clean && rm -rf dist",
    "dev": "pnpm sync-submodules && pnpm tokens:site && pnpm astro:dev",
    "preview": "pnpm astro:preview",
    "test": "pnpm tokens:test",
    "tokens": "pnpm tokens:build",
    "tokens:build": "node build/tokens/build.js",
    "tokens:lint": "eslint --cache --cache-location .cache/.eslintcache build/tokens",
    "tokens:site": "pnpm tokens:build --brand chassis --app docs",
    "tokens:test": "vitest run --dir build/tokens/test",
    "tokens:zip": "node build/zip-tokens.js",
    "site": "pnpm site:build && pnpm site:lint",
    "site:build": "pnpm sync-submodules && pnpm astro:build",
    "site:clean": "rm -rf _site site/node_modules site/.astro site/public",
    "site:format": "prettier --write --cache site",
    "site:lint": "pnpm site:lint:eslint && pnpm site:lint:fusv && pnpm site:lint:stylelint && pnpm site:lint:prettier && pnpm site:lint:vnu",
    "site:lint:eslint": "eslint site --cache --cache-location .cache/.eslintcache --report-unused-disable-directives",
    "site:lint:fusv": "find-unused-sass-variables site/src/scss/",
    "site:lint:prettier": "prettier -c --cache site",
    "site:lint:stylelint": "stylelint site/src/scss/ --cache --cache-location .cache/.stylelintcache",
    "site:lint:vnu": "node build/vnu-jar.js",
    "astro:dev": "astro dev --root site --port 4322",
    "astro:build": "astro build --root site",
    "astro:preview": "astro preview --root site",
    "check": "pnpm check:code & pnpm check:lockfile & pnpm check:pnpm & wait",
    "check:code": "pnpm site:lint",
    "check:lockfile": "lockfile-lint --allowed-hosts npm --allowed-schemes https: --empty-hostname false --type npm --path package-lock.json",
    "check:pnpm": "pnpm audit --audit-level moderate",
    "change-version": "node build/change-version.js",
    "sync-submodules": "node build/sync-submodules.js"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^6.3.11",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/prism": "^3.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "@chassis-ui/css": "github:chassis-ui/css#app/docs",
    "@chassis-ui/docs": "^0.1.9",
    "@chassis-ui/icons": "github:chassis-ui/icons#app/docs",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@eslint/js": "^9.39.4",
    "@stackblitz/sdk": "^1.11.0",
    "@tokens-studio/sd-transforms": "^1.3.0",
    "@types/google.analytics": "^0.0.46",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.19.17",
    "@types/prismjs": "^1.26.6",
    "@vitest/coverage-v8": "3.2.4",
    "astro": "^5.18.1",
    "astro-auto-import": "^0.4.6",
    "autoprefixer": "^10.5.0",
    "clean-css-cli": "^5.6.3",
    "clipboard": "^2.0.11",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "find-unused-sass-variables": "^6.1.1",
    "fuse.js": "^7.3.0",
    "github-slugger": "^2.0.0",
    "globals": "^16.5.0",
    "htmlparser2": "^10.1.0",
    "image-size": "^2.0.2",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "lockfile-lint": "^4.14.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prismjs": "^1.30.0",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sass": "^1.99.0",
    "standard": "^17.1.2",
    "style-dictionary": "^4.4.0",
    "stylelint": "^16.26.1",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "tinycolor2": "^1.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^3.2.4",
    "vnu-jar": "23.4.11",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
