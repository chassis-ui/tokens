---
/**
 * Gallery Section
 *
 * Display component gallery images with light/dark mode variants.
 */

import ResponsiveImage from '@chassis-ui/docs/components/ResponsiveImage.astro'
---

<section id="gallery-section" class="home-section py-6xlarge" style="--gallery-image-height: 96px;">
  <div class="container 2xlarge section-content">
    <div class="overflow-hidden rounded">
      <div class="gallery-image bg-evident top-50 position-relative translate-middle-y">
        <ResponsiveImage
          imgPath="/static/images/home/comp-gallery-light.png"
          alt="Chassis UI"
          classes="mb-5xlarge image fluid w-100 visible-light t-0"
        />
        <ResponsiveImage
          imgPath="/static/images/home/comp-gallery-dark.png"
          alt="Chassis UI"
          classes="mb-5xlarge image fluid w-100 visible-dark"
        />
      </div>
    </div>
  </div>
</section>
