---
import FeatureCard from '@chassis-ui/docs/components/FeatureCard.astro'
---

<section class="home-section py-3xlarge py-medium-6xlarge">
  <div class="container-2xlarge section-content">
    <div class="row mb-3xlarge mb-medium-6xlarge">
      <header class="section-header col col-large-10 col-xlarge-8 text-center mx-auto">
        <h2
          class="section-title font-3xlarge font-medium-4xlarge font-large-5xlarge mb-xsmall mb-medium-small mb-large-medium"
        >
          <span class="font-normal d-block">Automated Pipeline</span> from Figma to Code
        </h2>
        <p class="section-body font-medium-large font-large-xlarge m-0">
          Chassis Tokens provide your team with a reliable method to deliver consistent interfaces
          across brands, products, and platforms, cutting down on coordination hassles.
        </p>
      </header>
    </div>

    <div class="section-features row row-cols-1 row-cols-medium-3 g-medium g-medium-xlarge">
      <div class="col">
        <FeatureCard icon="cx-swatchbook">
          <Fragment slot="title">Multi-Brand Token Inheritance</Fragment>
          <Fragment slot="body">
            Manage multiple brand identities from a single repository. Switch brands instantly in
            design and code while maintaining consistent token structure.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-laptop-mobile">
          <Fragment slot="title">Platform-Native Code Generation</Fragment>
          <Fragment slot="body">
            One source of truth generates optimized tokens for web (SCSS/CSS), iOS (Swift), and
            Android (XML) with platform-native conventions.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-figma">
          <Fragment slot="title">Figma Variables Integration</Fragment>
          <Fragment slot="body">
            Design with tokens directly in Figma using Variables. Changes sync automatically between
            design files and code repositories.
          </Fragment>
        </FeatureCard>
      </div>
    </div>
  </div>
</section>
