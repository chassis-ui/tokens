---
import FeatureCard from '@chassis-ui/docs/components/FeatureCard.astro'
---

<section class="home-section py-3xlarge medium:py-6xlarge">
  <div class="container 2xlarge section-content">
    <div class="row mb-3xlarge medium:mb-6xlarge">
      <header class="section-header col large:col-10 xlarge:col-8 text-center mx-auto">
        <h2
          class="section-title font-3xlarge medium:font-4xlarge large:font-5xlarge mb-xsmall medium:mb-small large:mb-medium"
        >
          <span class="font-normal d-block">Built on</span> Industry Standards
        </h2>
        <p class="section-body medium:font-large large:font-xlarge m-0">
          Powered by battle-tested tools and open standards, Chassis Tokens fits into your existing
          stack without custom infrastructure or vendor lock-in.
        </p>
      </header>
    </div>

    <div class="section-features row row-cols-2 medium:row-cols-4 g-medium medium:g-xlarge">
      <div class="col">
        <FeatureCard>
          <Fragment slot="title">Tokens Studio</Fragment>
          <Fragment slot="body">Token management</Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard>
          <Fragment slot="title">Style Dictionary</Fragment>
          <Fragment slot="body">Token transformation</Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard>
          <Fragment slot="title">Figma Variables</Fragment>
          <Fragment slot="body">Design integration</Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard>
          <Fragment slot="title">DTCG Format</Fragment>
          <Fragment slot="body">W3C token standard</Fragment>
        </FeatureCard>
      </div>
    </div>
  </div>
</section>
