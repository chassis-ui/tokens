---
import { getConfig } from '@libs/config'
import ResponsiveImage from '@shortcodes/ResponsiveImage.astro'
import Code from '@shortcodes/Code.astro'
import { getChassisDocsPath } from '@libs/path'
import Card from '@components/Card.astro'
---

<section class="py-6xlarge">
  <div class="container">
    <div class="row justify-content-center mb-5xlarge">
      <div class="col-large-8 text-center">
        <h2 class="font-hero mb-medium">Built on Industry Standards</h2>
        <p class="font-lead">
          Powered by battle-tested tools and open standards, Chassis Tokens fits into your existing
          stack without custom infrastructure or vendor lock-in.
        </p>
      </div>
    </div>

    <div class="row row-cols-2 row-cols-medium-4 g-xlarge text-center">
      <div class="col">
        <div class="card p-xlarge">
          <div class="card-content">
            <h4 class="card-title">Tokens Studio</h4>
            <p class="card-body">Token management</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card p-xlarge">
          <div class="card-content">
            <h4 class="card-title">Style Dictionary</h4>
            <p class="card-body">Token transformation</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card p-xlarge">
          <div class="card-content">
            <h4 class="card-title">Figma Variables</h4>
            <p class="card-body">Design integration</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card p-xlarge">
          <div class="card-content">
            <h4 class="card-title">DTCG Format</h4>
            <p class="card-body">W3C token standard</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
