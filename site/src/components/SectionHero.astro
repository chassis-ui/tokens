---
import { getConfig } from '@libs/config'
import ResponsiveImage from '@shortcodes/ResponsiveImage.astro'
import Code from '@shortcodes/Code.astro'
import { getChassisDocsPath } from '@libs/path'
---

<section class="py-6xlarge cxd-masthead">
  <div class="container py-6xlarge">
    <div class="row justify-content-center">
      <div class="col-large-10 col-xlarge-12 text-center">
        <h1 class="font-jumbo mb-large">
          <span class="font-normal">Scale Your Design System Across</span> Brands, Themes & Platforms
        </h1>
        <p class="font-lead">
          Enterprise-grade design token system that bridges design and development. One source of
          truth, infinite possibilities.
        </p>
        <div class="d-flex gap-medium justify-content-center flex-wrap py-4xlarge">
          <a href="/getting-started" class="button primary large cxd-button">
            <svg class="icon" aria-hidden="true"><use xlink:href="#book-open-solid"></use></svg>
            <span>Get Started</span>
          </a>
          <a
            href="https://github.com/chassis-ui/tokens"
            class="button default large cxd-button"
            target="_blank"
            rel="noopener"
          >
            <svg class="icon" aria-hidden="true"><use xlink:href="#github-brand"></use></svg>
            <span>View on GitHub</span>
          </a>
        </div>
        <p class="text-body-secondary mb-0">
          Currently <strong>v{getConfig().current_version}</strong>
          <span class="px-1">&middot;</span>
          <a href={getChassisDocsPath('getting-started/download')} class="link-secondary"
            >Download</a
          >
          <span class="px-1">&middot;</span>
          <a href="/docs/versions/" class="link-secondary text-nowrap">All releases</a>
        </p>
      </div>
    </div>
  </div>
</section>
