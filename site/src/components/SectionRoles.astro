---
import FeatureCard from '@chassis-ui/docs/components/FeatureCard.astro'
---

<section class="home-section py-3xlarge py-medium-6xlarge">
  <div class="container-2xlarge section-content">
    <div class="row mb-3xlarge mb-medium-6xlarge">
      <div class="section-header col col-large-10 col-xlarge-8 text-center mx-auto">
        <h2
          class="section-title font-3xlarge font-medium-4xlarge font-large-5xlarge mb-xsmall mb-medium-small mb-large-medium"
        >
          <span class="font-normal d-block">Built for</span> Your Role
        </h2>
        <p class="section-body font-medium-large font-large-xlarge m-0">
          Whatever your role is, Chassis Tokens reduces coordination overhead so product, design,
          and engineering can move in lockstep.
        </p>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-medium-3 g-medium g-medium-xlarge">
      <div class="col">
        <FeatureCard icon="cx-chess-horse">
          <Fragment slot="title">Product Managers</Fragment>
          <Fragment slot="body">
            Drive faster go-to-market cycles with a unified design system that eliminates
            bottlenecks between teams. Coordinate product launches with confidence knowing your
            brand identity stays consistent across every touchpoint.
          </Fragment>
          <ul class="list-unstyled p-0 d-flex flex-column gap-small">
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Launch new brands in weeks, not months</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Maintain consistency across product portfolio</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Scale operations without scaling headcount</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Accelerate feature delivery with reusable tokens</span>
            </li>
          </ul>
        </FeatureCard>
      </div>

      <div class="col">
        <FeatureCard icon="cx-palette">
          <Fragment slot="title">Design Leads</Fragment>
          <Fragment slot="body">
            Establish a single source of truth for your design system that bridges Figma and code.
            Empower your team to iterate fearlessly while maintaining pixel-perfect consistency
            across platforms.
          </Fragment>
          <ul class="list-unstyled p-0 d-flex flex-column gap-small">
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Perfect design-developer handoff every time</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Manage tokens directly in Figma with Variables</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Version control for design decisions</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Centralized design system documentation</span>
            </li>
          </ul>
        </FeatureCard>
      </div>

      <div class="col">
        <FeatureCard icon="cx-code">
          <Fragment slot="title">CTOs & Tech Leads</Fragment>
          <Fragment slot="body">
            Build scalable, maintainable design infrastructure with automated token generation and
            type-safe implementations. Reduce technical debt while accelerating development velocity
            across all platforms.
          </Fragment>
          <ul class="list-unstyled p-0 d-flex flex-column gap-small">
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Type-safe tokens with automated generation</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Framework-agnostic, works with any tech stack</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Dramatically reduce CSS complexity</span>
            </li>
            <li class="d-flex gap-small">
              <svg class="icon fg-success" aria-hidden="true">
                <use href="#cx-check-circle"></use>
              </svg>
              <span>Built-in accessibility compliance</span>
            </li>
          </ul>
        </FeatureCard>
      </div>
    </div>
  </div>
</section>
