---
import FeatureCard from '@chassis-ui/docs/components/FeatureCard.astro'
---

<section class="home-section py-3xlarge py-medium-6xlarge">
  <div class="container-2xlarge section-content">
    <div class="row mb-3xlarge mb-medium-6xlarge">
      <div class="section-header col col-large-10 col-xlarge-8 text-center mx-auto">
        <h2
          class="section-title font-3xlarge font-medium-4xlarge font-large-5xlarge mb-xsmall mb-medium-small mb-large-medium"
        >
          <span class="font-normal d-block">Enterprise-Grade</span> Token Management
        </h2>
        <p class="section-body font-medium-large font-large-xlarge m-0">
          A multi-brand, multi-theme, multi-application token architecture that keeps colors,
          typography, spacing, and more in sync across every brand, color mode, app, and platform.
        </p>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-medium-2 g-medium g-medium-xlarge">
      <div class="col">
        <FeatureCard icon="cx-swatchbook">
          <Fragment slot="title">Multi-Brand Architecture</Fragment>
          <Fragment slot="body">
            Manage multiple brand identities from a single repository. Switch brands instantly in
            design and code while maintaining consistent token structure.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-palette">
          <Fragment slot="title">Theme Variations</Fragment>
          <Fragment slot="body">
            Light mode, dark mode, high contrast—all working seamlessly. Independent theme switching
            that works across every brand and platform.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-laptop-mobile">
          <Fragment slot="title">Cross-Platform Generation</Fragment>
          <Fragment slot="body">
            One source of truth generates optimized tokens for web (SCSS/CSS), iOS (Swift), and
            Android (XML) with platform-native conventions.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-figma">
          <Fragment slot="title">Figma Integration</Fragment>
          <Fragment slot="body">
            Design with tokens directly in Figma using Variables. Changes sync automatically between
            design files and code repositories.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-refresh">
          <Fragment slot="title">Automated Workflows</Fragment>
          <Fragment slot="body">
            Style Dictionary transforms tokens automatically. Version control with Git. CI/CD ready.
            Zero manual token management.
          </Fragment>
        </FeatureCard>
      </div>
      <div class="col">
        <FeatureCard icon="cx-code">
          <Fragment slot="title">Developer-Friendly</Fragment>
          <Fragment slot="body">
            Import as SCSS variables, CSS custom properties, or JavaScript objects. TypeScript
            definitions included. Works with any bundler.
          </Fragment>
        </FeatureCard>
      </div>
    </div>
  </div>
</section>
