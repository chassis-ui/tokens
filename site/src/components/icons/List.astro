---
import { iconsPages } from '@libs/content'
import { getDocsStaticFsPath } from '@libs/path'
import path from 'node:path'

interface Props {
  icons?: typeof iconsPages
  showSearch?: boolean
  title?: string
}

const {
  icons = iconsPages,
  showSearch = true,
  title = "Icons"
} = Astro.props
---
<section id="icons-section">
  <header class="d-flex my-2xlarge">
    <h2 id="icons">{title}</h2>
    {showSearch && (
      <form class="flex-nowrap ms-auto" onsubmit="return false">
        <label for="search" class="visually-hidden">Search for icons</label>
        <input class="form-input search mb-0" id="search" type="search" placeholder="Start typing to filter..." autocomplete="off" />
      </form>
    )}
  </header>
  <ul id="icons-list" class="row row-cols-3 gy-medium row-cols-small-4 row-cols-large-6 row-cols-xlarge-8 bulletless icon-list icon-xlarge">
    {icons.map((iconPage) => {
      const filename = iconPage.id.split('/').pop()?.replace('.mdx', '')
      if (!filename) return null
      return (
        <li class="col"
            data-name={filename}
            data-tags={iconPage.data.tags?.split(',')?.join(' ').toLowerCase()}
            data-categories={iconPage.data.categories?.split(',')?.join(' ').toLowerCase()}>
          <a class="d-block text-decoration-none" href={`/docs/icons/${filename}`}>
            <div class="bg-even py-3xlarge text-center rounded">
              <svg class="icon">
                <use xlink:href={`#${filename}`}/>
              </svg>
            </div>
            <div class="name text-muted text-decoration-none text-center">{filename}</div>
          </a>
        </li>
      )
    })}
  </ul>
</section>
<Fragment slot="scripts">
  <script type="module" src="/assets/icons-docs/icon-search.js"></script>
</Fragment>
