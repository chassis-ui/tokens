---
import BaseLayout from '@layouts/BaseLayout.astro'
import Masthead from '@components/home/Masthead.astro'
import Card from '@components/home/Card.astro'
import PageSection from '@components/common/PageSection.astro'
---

<BaseLayout title="Chassis Tokens">
  <PageSection content={Masthead} rowClass="row py-6xlarge" />
  <PageSection containerClass="container" rowClass="row row-cols-2 g-xlarge py-6xlarge">
    <div class="col">
      <Card
        title="Welcome to Chassis Tokens"
        body="Chassis Tokens is an open-source design token library that provides a solid foundation for building consistent and scalable user interfaces."
        icon="rocket-outline"
      />
    </div>
    <div class="col">
      <Card
        title="Multi-Brand Support"
        body="Easily manage tokens for multiple brands, themes, and apps in a single repository. Chassis Tokens makes it simple to scale your design system across products and platforms."
        icon="swatchbook-outline"
      />
    </div>
    <div class="col">
      <Card
        title="Style Dictionary Integration"
        body="Transform tokens into platform-ready formats using Style Dictionary. Export SCSS, Swift, XML, and more for seamless integration with your codebase."
        icon="palette-outline"
      />
    </div>
    <div class="col">
      <Card
        title="Comprehensive Documentation"
        body="Get started quickly with detailed guides, API docs, and usage examples. The documentation site helps you extend, customize, and integrate tokens with confidence."
        icon="book-open-outline"
      />
    </div>
  </PageSection>
</BaseLayout>
