---
import BaseLayout from '@chassis-ui/docs/layouts/BaseLayout.astro'
import HeroSection from '@components/sections/HeroSection.astro'
import GallerySection from '@components/sections/GallerySection.astro'
import CoreSection from '@components/sections/CoreSection.astro'
import FeaturesSection from '@components/sections/FeaturesSection.astro'
import HowSection from '@components/sections/HowSection.astro'
import TechSection from '@components/sections/TechSection.astro'
import DocsSection from '@components/sections/DocsSection.astro'
import HomeIcons from '/static/icons/cx-sprite.svg?raw'
// import '@chassis-ui/docs/scss/home.scss'
---

<BaseLayout title="Chassis Tokens - Enterprise Design Token System">
  <!-- Hero Section -->
  <HeroSection />
  <hr class="hr container" />
  <!-- Core Features (3 cards) -->
  <FeaturesSection />
  <!-- Additional Features (6 cards) -->
  <CoreSection />
  <!-- How It Works (3 steps) -->
  <HowSection />
  <!-- Technical Stack -->
  <TechSection />
  <!-- Documentation Section -->
  <DocsSection />
  <div class="d-none">
    <Fragment set:html={HomeIcons} />
  </div>
</BaseLayout>
