{
  "figma": {
    "switch": {
      "screen": {
        "mode-1": {
          "$type": "boolean",
          "$value": "false"
        },
        "mode-2": {
          "$type": "boolean",
          "$value": "true"
        }
      }
    }
  },
  "visibility": {
    "screen": {
      "separator": {
        "$type": "boolean",
        "$value": "{figma.switch.screen.mode-1}"
      }
    }
  },
  "typography": {
    "fontSize": {
      "screen": {
        "hero-title": {
          "$type": "fontSize",
          "$value": "48"
        },
        "hero-body": {
          "$type": "fontSize",
          "$value": "18"
        },
        "section-title": {
          "$type": "fontSize",
          "$value": "32"
        },
        "section-body": {
          "$type": "fontSize",
          "$value": "18"
        },
        "feature-title": {
          "$type": "fontSize",
          "$value": "20"
        },
        "feature-body": {
          "$type": "fontSize",
          "$value": "16"
        },
        "button-label": {
          "$type": "fontSize",
          "$value": "18"
        }
      }
    }
  },
  "space": {
    "screen": {
      "section-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.64}"
