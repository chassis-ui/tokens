      },
      "section-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.48}"
      },
      "content-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "content-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.0}"
      },
      "content-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "content-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "card-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "card-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.0}"
      },
      "card-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "card-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "button-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "button-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "button-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      },
      "button-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.24}"
      }
    }
  },
  "size": {
    "screen": {
      "icon-frame": {
        "$type": "sizing",
        "$value": "{size.base.48}"
      },
      "icon-glyph": {
        "$type": "sizing",
        "$value": "{size.base.40}"
      },
      "section-w": {
        "$type": "sizing",
        "$value": "{grid.breakpoint.xlarge}"
      },
      "section-h": {
        "$type": "sizing",
        "$value": "1024"
      }
