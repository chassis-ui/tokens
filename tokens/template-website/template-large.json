{
  "figma": {
    "switch": {
      "template": {
        "mode-1": {
          "$type": "boolean",
          "$value": "true"
        }
      }
    }
  },
  "visibility": {
    "template": {
      "separator": {
        "$type": "boolean",
        "$value": "{figma.switch.breakpoint.mode-1}"
      }
    }
  },
  "typography": {
    "font-size": {
      "template": {
        "hero-title": {
          "$type": "typography",
          "$value": "{size.base.64}"
        },
        "hero-body": {
          "$type": "typography",
          "$value": "{size.base.32}"
        },
        "section-title": {
          "$type": "typography",
          "$value": "{size.base.38}"
        },
        "section-body": {
          "$type": "typography",
          "$value": "{size.base.16}"
        },
        "feature-title": {
          "$type": "typography",
          "$value": "{size.base.24}"
        },
        "feature-body": {
          "$type": "typography",
          "$value": "{size.base.16}"
        }
      }
    }
  },
  "space": {
    "template": {
      "section-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.96}"
      },
      "section-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "section-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.96}"
      },
      "section-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.64}"
      },
      "feature-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "feature-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.0}"
      },
      "feature-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "feature-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      }
    }
  },
  "size": {
    "template": {
      "icon-frame": {
        "$type": "sizing",
        "$value": "{size.base.56}"
      },
      "icon-glyph": {
        "$type": "sizing",
        "$value": "{size.base.48}"
      },
      "section-w": {
        "$type": "sizing",
        "$value": "{grid.breakpoint.xlarge}"
      }
    }
  }
}