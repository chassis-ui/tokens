        "$value": "'Archivo Narrow', Georgia, 'Times New Roman', Times, serif"
      },
      "code": {
        "$type": "fontFamilies",
        "$value": "Fira Code, Menlo, Monaco, Consolas, 'Courier New', monospace"
      },
      "icon": {
