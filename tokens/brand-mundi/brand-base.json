{
  "figma": {
    "switch": {
      "brand": {
        "mode-1": {
          "$type": "boolean",
          "$value": "true"
        }
      }
    }
  },
  "color": {
    "base": {
      "palette": {
        "light": {
          "neutral": {
            "base": {
              "$type": "color",
              "$value": "#86898B"
            }
          },
          "danger": {
            "base": {
              "$type": "color",
              "$value": "#F52314"
            }
          },
          "success": {
            "base": {
              "$type": "color",
              "$value": "#23C16B"
            }
          },
          "warning": {
            "base": {
              "$type": "color",
              "$value": "#FFB323"
            },
            "contrast": {
              "$type": "color",
              "$value": "{color.base.palette.light.black.base}"
            }
          },
          "info": {
            "base": {
              "$type": "color",
              "$value": "#48A7F8"
            }
          },
          "brand": {
            "base": {
              "$type": "color",
              "$value": "#3527DD"
            }
          },
          "accent": {
            "base": {
              "$type": "color",
              "$value": "#3527DD"
            }
          }
        }
      }
    }
  },
