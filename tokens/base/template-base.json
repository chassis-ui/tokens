{
  "figma": {
    "switch": {
      "template": {
        "mode-1": {
          "$type": "boolean",
          "$value": "false"
        },
        "mode-2": {
          "$type": "boolean",
          "$value": "false"
        },
        "mode-3": {
          "$type": "boolean",
          "$value": "false"
        }
      }
    }
  },
  "visibility": {
    "template": {
      "separator": {
        "$type": "boolean",
        "$value": "{figma.switch.breakpoint.mode-1}"
      }
    }
  },
  "space": {
    "template": {
      "section-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.96}"
      },
      "section-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "section-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.96}"
      },
      "section-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.64}"
      },
      "feature-padding-y": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "feature-padding-x": {
        "$type": "spacing",
        "$value": "{space.base.0}"
      },
      "feature-gap-y": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      },
      "feature-gap-x": {
        "$type": "spacing",
        "$value": "{space.base.32}"
      }
    }
  },
  "size": {
    "template": {
      "icon-frame": {
        "$type": "sizing",
        "$value": "{size.base.56}"
      },
      "icon-glyph": {
        "$type": "sizing",
        "$value": "{size.base.48}"
      },
      "section-w": {
        "$type": "sizing",
        "$value": "{grid.breakpoint.xlarge}"
      }
    }
  }
}